# docker -------------------
COMPOSE_PROJECT_NAME=django_app

# db -------------------
POSTGRES_DB=dev_db
POSTGRES_USER=root
POSTGRES_PASSWORD=secret
DB_HOST=db
DB_PORT=5432
DB_EXPOSE_PORT=5432

# app -------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=${POSTGRES_DB}
DB_USER=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}
APP_PORT=8000
APP_EXPOSE_PORT=8000

SRC_PATH=./src